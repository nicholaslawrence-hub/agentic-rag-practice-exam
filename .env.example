# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=mcb-tutor

# ── OpenAI (embeddings) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (generation + classification) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith (tracing) ───────────────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mcb-tutor

# ── Postgres (Neon) ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# ── Auth (shared secret between Next.js NextAuth and FastAPI) ─────────────────
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── Resend (magic-link fallback) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
DAILY_MESSAGE_QUOTA=50
